# Server
PORT=3000
NODE_ENV=development

# Python TextFSM + Network Tools backend
PYTHON_BACKEND_PORT=8001

# MySQL Database (required — create with: CREATE DATABASE ost_network_tools)
DATABASE_URL=mysql://root:@localhost:3306/ost_network_tools

# JWT Authentication (change in production!)
JWT_SECRET=ost-dev-secret-change-in-production

# Allow self-signed TLS certificates from AOS switches
NODE_TLS_REJECT_UNAUTHORIZED=0

# Syslog receiver (UDP) — switches send logs via "swlog output socket <server_ip>"
SYSLOG_PORT=514

# Auto-collection interval in seconds (default: 30)
COLLECT_INTERVAL=30
